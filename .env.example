# Copy to .env and adjust. .env is git-ignored and must never be committed.

# --- Application ---
SCTOWER_ENV=local
SCTOWER_LOG_LEVEL=INFO
SCTOWER_LOG_JSON=false

# --- Data paths (relative to repo root) ---
SCTOWER_DATA_RAW_DIR=data/raw
SCTOWER_DATA_CURATED_DIR=data/curated

# --- Database (Postgres serving store) ---
# Used by docker-compose. For pure-file local runs, leave the default.
SCTOWER_DB_URL=postgresql+psycopg://sctower:sctower@localhost:5432/sctower

# --- Inventory policy defaults ---
SCTOWER_SERVICE_LEVEL=0.95
SCTOWER_LEAD_TIME_DAYS=7

# --- Forecasting ---
SCTOWER_FORECAST_HORIZON_DAYS=42
SCTOWER_BACKTEST_FOLDS=4
